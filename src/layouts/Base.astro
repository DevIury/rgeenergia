---
import { ClientRouter } from "astro:transitions";
interface Props {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    faq?: { question: string; answer: string }[];
}
const { title, description, canonical = 'https://rgeenergia.com.br', ogImage = '/img/hero-bg.webp', faq } = Astro.props;
const siteUrl = 'https://rgeenergia.com.br';
const currentPath = Astro.url.pathname;

const orgSchema = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": siteUrl,
    name: "RGE Soluções em Energia",
    alternateName: "RGE Energia",
    description,
    url: siteUrl,
    telephone: "+553835021309",
    email: "contato@rgeenergia.com.br",
    address: {
        "@type": "PostalAddress",
        streetAddress: "R. José Reinaldo A. Corrêa, 127",
        addressLocality: "Curvelo",
        addressRegion: "MG",
        postalCode: "35790-000",
        addressCountry: "BR"
    },
    geo: { "@type": "GeoCoordinates", latitude: -18.7548, longitude: -44.4553 },
    image: `${siteUrl}/img/hero-bg.webp`,
    priceRange: "$$",
    openingHoursSpecification: [
        { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "08:00", closes: "18:00" },
        { "@type": "OpeningHoursSpecification", dayOfWeek: "Saturday", opens: "08:00", closes: "12:00" }
    ],
    sameAs: [
        "https://www.facebook.com/rgeenergia",
        "https://www.instagram.com/rgeenergia",
        "https://www.linkedin.com/company/rge-solucoes-em-energia"
    ],
    areaServed: [
        { "@type": "City", name: "Curvelo" },
        { "@type": "State", name: "Minas Gerais" }
    ],
    hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Serviços de Energia",
        itemListElement: [
            { "@type": "Offer", itemOffered: { "@type": "Service", name: "Energia Solar Fotovoltaica" } },
            { "@type": "Offer", itemOffered: { "@type": "Service", name: "Eficiência Energética" } },
            { "@type": "Offer", itemOffered: { "@type": "Service", name: "Projetos Elétricos" } },
            { "@type": "Offer", itemOffered: { "@type": "Service", name: "Subestações" } }
        ]
    }
};

const faqSchema = faq ? {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map(f => ({
        "@type": "Question",
        name: f.question,
        acceptedAnswer: { "@type": "Answer", text: f.answer }
    }))
} : null;
---
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#22c55e">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={canonical}>
    <meta name="robots" content="index, follow">
    <meta name="keywords" content="energia solar, painel solar, fotovoltaica, Curvelo, Minas Gerais, economia de energia">
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonical}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={`${siteUrl}${ogImage}`}>
    <meta property="og:locale" content="pt_BR">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"></noscript>
    <link rel="stylesheet" href="/global.css">
    <script>
    document.addEventListener('astro:page-load', function() {
        document.querySelectorAll('a[href^="#"]').forEach(function(a) {
            a.addEventListener('click', function(e) {
                var href = a.getAttribute('href');
                if (href && href.startsWith('#') && href.length > 1) {
                    e.preventDefault();
                    var t = document.querySelector(href);
                    if (t) window.scrollTo({ top: t.offsetTop - 70, behavior: 'smooth' });
                }
            });
        });
    });
    </script>
    <ClientRouter />
    <script is:inline>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(() => {});
            });
        }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</head>
<body>
<nav class="nav" id="nav">
    <div class="nav-inner container">
        <a href="/" class="logo">
            <img src="/img/logo.svg" alt="RGE Energia" class="logo-img">
        </a>
        <div class="nav-links" id="navLinks">
            <div class="nav-mobile-top">
                <a href="/" class="logo"><img src="/img/logo.svg" alt="RGE Energia" class="logo-img"></a>
                <button class="nav-close" id="navClose" aria-label="Fechar menu">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <nav class="nav-mobile-links">
                <a href="/" class:list={{ active: currentPath === '/' }}>
                    <i class="fas fa-home"></i> Inicio
                </a>
                <a href="/sobre" class:list={{ active: currentPath === '/sobre' }}>
                    <i class="fas fa-building"></i> Sobre
                </a>
                <a href="/servicos" class:list={{ active: currentPath.startsWith('/servicos') }}>
                    <i class="fas fa-bolt"></i> Servicos
                </a>
                <a href="/projetos" class:list={{ active: currentPath === '/projetos' }}>
                    <i class="fas fa-project-diagram"></i> Projetos
                </a>
                <a href="/blog" class:list={{ active: currentPath.startsWith('/blog') }}>
                    <i class="fas fa-newspaper"></i> Blog
                </a>
                <a href="/contato" class:list={{ active: currentPath === '/contato' }}>
                    <i class="fas fa-envelope"></i> Contato
                </a>
            </nav>
        </div>
        <a href="/contato" class="btn btn-green nav-cta">Fale Conosco</a>
        <button class="hamburger" id="hamburger" aria-label="Abrir menu de navegação" aria-expanded="false" aria-controls="navLinks">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

<slot />

<footer class="footer">
    <div class="container footer-inner">
        <div class="footer-brand">
            <a href="/" class="logo"><img src="/img/logo.svg" alt="RGE Energia" class="logo-img"></a>
            <p>Especialistas em <strong>energia solar fotovoltaica</strong> para residencias, comercios e industrias em Curvelo/MG e regiao.</p>
            <div class="socials">
                <a href="https://www.facebook.com/rgeenergia" target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a>
                <a href="https://www.instagram.com/rgeenergia" target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a>
                <a href="https://www.linkedin.com/company/rge-solucoes-em-energia" target="_blank" rel="noopener"><i class="fab fa-linkedin-in"></i></a>
                <a href="https://wa.me/5538999901309" target="_blank" rel="noopener"><i class="fab fa-whatsapp"></i></a>
            </div>
        </div>
        <div class="footer-col">
            <h4>Navegacao</h4>
            <ul>
                <li><a href="/">Inicio</a></li>
                <li><a href="/sobre">Sobre</a></li>
                <li><a href="/servicos">Servicos</a></li>
                <li><a href="/projetos">Projetos</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/contato">Contato</a></li>
            </ul>
        </div>
        <div class="footer-col">
            <h4>Servicos</h4>
            <ul>
                <li><a href="/servicos/energia-solar">Energia Solar</a></li>
                <li><a href="/servicos/eficiencia-energetica">Eficiencia Energetica</a></li>
                <li><a href="/servicos/projetos-eletricos">Projetos Eletricos</a></li>
                <li><a href="/servicos/subestacoes">Subestacoes</a></li>
            </ul>
        </div>
        <div class="footer-col">
            <h4>Contato</h4>
            <ul>
                <li><i class="fas fa-map-marker-alt"></i> R. Jose Reinaldo A. Correa, 127</li>
                <li><i class="fas fa-phone-alt"></i> <a href="tel:3835021309">(38) 3502-1309</a></li>
                <li><i class="fab fa-whatsapp"></i> <a href="https://wa.me/5538999901309">(38) 9 9990-1309</a></li>
            </ul>
        </div>
    </div>
    <div class="footer-bottom container">
        <span>&copy; 2026 RGE Energia. Todos os direitos reservados.</span>
        <span>Desenvolvido por <a href="https://flowdigital.marketing/" target="_blank" rel="noopener">Flow Digital</a></span>
    </div>
</footer>

<a href="https://wa.me/5538999901309" class="wa-float" target="_blank" rel="noopener" aria-label="WhatsApp">
    <i class="fab fa-whatsapp"></i>
    <span class="wa-tooltip">Fale Conosco</span>
</a>

<script is:inline src="/nav.js"></script>
</body>
</html>
