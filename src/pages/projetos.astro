---
import Base from '../layouts/Base.astro';
---
<Base title="Projetos RGE Energia | Veja Nossos Resultados" description="Conheça os projetos realizados pela RGE Energia: sistemas solares residenciais, comerciais e rurais em Curvelo/MG.">

    <section class="page-hero">
        <div class="page-hero-bg"><img src="/img/proj-urbano.webp" alt="Projetos RGE" loading="lazy" decoding="async"><div class="page-hero-overlay"></div></div>
        <div class="container page-hero-content">
            <nav class="breadcrumb"><a href="/">Home</a><span>/</span><span>Projetos</span></nav>
            <h1>Nossos <span>projetos</span></h1>
            <p>Veja o impacto real da energia solar nos nossos clientes</p>
        </div>
    </section>

    <section class="proj-filtros">
        <div class="container">
            <div class="filter-row">
                <button class="filter-btn active" data-filter="all">Todos</button>
                <button class="filter-btn" data-filter="residencial">Residencial</button>
                <button class="filter-btn" data-filter="comercial">Comercial</button>
                <button class="filter-btn" data-filter="rural">Rural</button>
                <button class="filter-btn" data-filter="industrial">Industrial</button>
            </div>
        </div>
    </section>

    <section class="proj-grid-section">
        <div class="container">
            <div class="proj-grid">
                <div class="proj-item" data-cat="residencial">
                    <div class="proj-img"><img src="/img/proj-urbano.webp" alt="Residencial Centro" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">RESIDENCIAL</span>
                        <h3>Sistema 8kWp</h3>
                        <p>Centro - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 350/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
                <div class="proj-item" data-cat="comercial">
                    <div class="proj-img"><img src="/img/proj-comercial.webp" alt="Comercial Loja" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">COMERCIAL</span>
                        <h3>Sistema 25kWp</h3>
                        <p>Loja de Materiais - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 5.200/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
                <div class="proj-item" data-cat="rural">
                    <div class="proj-img"><img src="/img/proj-rural.webp" alt="Rural Fazenda" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">RURAL</span>
                        <h3>Sistema 45kWp</h3>
                        <p>Fazenda Boa Vista - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 7.800/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
                <div class="proj-item" data-cat="residencial">
                    <div class="proj-img"><img src="/img/proj-urbano.webp" alt="Residencial Bairro" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">RESIDENCIAL</span>
                        <h3>Sistema 12kWp</h3>
                        <p>Bairro Santa Terezinha - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 480/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
                <div class="proj-item" data-cat="comercial">
                    <div class="proj-img"><img src="/img/proj-comercial.webp" alt="Comercial Hotel" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">COMERCIAL</span>
                        <h3>Sistema 60kWp</h3>
                        <p>Pousada Serra Azul - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 12.000/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
                <div class="proj-item" data-cat="industrial">
                    <div class="proj-img"><img src="/img/energy-pylons.webp" alt="Industrial Fábrica" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">INDUSTRIAL</span>
                        <h3>Sistema 100kWp</h3>
                        <p>Indústria Alimentícia - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 18.500/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
                <div class="proj-item" data-cat="rural">
                    <div class="proj-img"><img src="/img/proj-rural.webp" alt="Rural Pecuária" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">RURAL</span>
                        <h3>Sistema 35kWp</h3>
                        <p>Fazenda São José - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 6.200/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
                <div class="proj-item" data-cat="residencial">
                    <div class="proj-img"><img src="/img/proj-urbano.webp" alt="Residencial Condomínio" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">RESIDENCIAL</span>
                        <h3>Sistema 50kWp</h3>
                        <p>Condomínio Horizonte - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 9.000/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
                <div class="proj-item" data-cat="comercial">
                    <div class="proj-img"><img src="/img/proj-comercial.webp" alt="Comercial Supermercado" loading="lazy" decoding="async"></div>
                    <div class="proj-info">
                        <span class="proj-type">COMERCIAL</span>
                        <h3>Sistema 80kWp</h3>
                        <p>Supermercado Central - Curvelo/MG</p>
                        <div class="proj-stats"><span><strong>R$ 15.000/mês</strong> de economia</span><span><strong>25 anos</strong> de garantia</span></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container cta-inner">
            <h2>Quer ver seu projeto aqui?</h2>
            <p>Fale conosco e comece a economizar com energia solar.</p>
            <div class="cta-btns">
                <a href="/contato" class="btn btn-green btn-xl">SOLICITAR ORÇAMENTO <i class="fas fa-arrow-right"></i></a>
                <a href="https://wa.me/5538999901309" class="btn btn-outline-green btn-xl" target="_blank"><i class="fab fa-whatsapp"></i> WHATSAPP</a>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('astro:page-load', () => {
            const btns = document.querySelectorAll('.filter-btn');
            const items = document.querySelectorAll('.proj-item');
            btns.forEach(btn => {
                btn.addEventListener('click', () => {
                    btns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    const f = btn.getAttribute('data-filter');
                    items.forEach(item => {
                        const el = item as HTMLElement;
                        if (f === 'all' || el.getAttribute('data-cat') === f) {
                            el.style.display = '';
                        } else {
                            el.style.display = 'none';
                        }
                    });
                });
            });
        });
    </script>

    <style>
        .page-hero { position: relative; padding: 100px 0 50px; overflow: hidden; }
        .page-hero-bg { position: absolute; inset: 0; }
        .page-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
        .page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,0,0,.9) 0%, rgba(0,0,0,.7) 100%); }
        .page-hero-content { position: relative; z-index: 1; }
        .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: .75rem; color: var(--gray); margin-bottom: 12px; }
        .breadcrumb a { color: var(--green); text-decoration: none; }
        .page-hero h1 { font-family: var(--font-display); font-size: 2rem; color: var(--white); margin-bottom: 8px; }
        .page-hero h1 span { color: var(--green); }
        .page-hero p { color: var(--gray); font-size: .95rem; }

        .proj-filtros { padding: 30px 0 10px; background: var(--black); }
        .filter-row { display: flex; flex-wrap: wrap; gap: 8px; }
        .filter-btn { padding: 8px 16px; background: var(--dark-2); border: 1px solid var(--dark-3); color: var(--gray); font-size: .8rem; font-weight: 600; border-radius: var(--radius-full); cursor: pointer; transition: .2s; }
        .filter-btn:hover, .filter-btn.active { background: var(--green); color: var(--black); border-color: var(--green); }

        .proj-grid-section { padding: 20px 0 60px; background: var(--black); }
        .proj-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
        .proj-item { background: var(--dark-2); border: 1px solid var(--dark-3); border-radius: var(--radius); overflow: hidden; transition: .3s; }
        .proj-item:hover { border-color: var(--green); }
        .proj-img { height: 180px; overflow: hidden; }
        .proj-img img { width: 100%; height: 100%; object-fit: cover; }
        .proj-info { padding: 16px; }
        .proj-type { display: inline-block; padding: 3px 8px; background: var(--green); color: var(--black); font-size: .55rem; font-weight: 700; border-radius: var(--radius-full); margin-bottom: 6px; }
        .proj-info h3 { color: var(--white); font-size: .95rem; margin-bottom: 4px; }
        .proj-info p { color: var(--gray); font-size: .8rem; margin-bottom: 8px; }
        .proj-stats { display: flex; flex-wrap: wrap; gap: 12px; }
        .proj-stats span { font-size: .7rem; color: var(--gray-light); }
        .proj-stats strong { color: var(--green); }

        .cta-section { padding: 50px 0; background: var(--dark); text-align: center; }
        .cta-inner h2 { font-family: var(--font-display); font-size: 1.5rem; color: var(--white); margin-bottom: 8px; }
        .cta-inner p { color: var(--gray); margin-bottom: 20px; font-size: .9rem; }
        .cta-btns { display: flex; flex-direction: column; gap: 10px; }

        @media(min-width:640px) {
            .page-hero h1 { font-size: 2.5rem; }
            .proj-grid { grid-template-columns: repeat(2, 1fr); }
            .proj-img { height: 220px; }
            .cta-btns { flex-direction: row; justify-content: center; }
        }
        @media(min-width:1024px) {
            .page-hero { padding: 140px 0 60px; }
            .page-hero h1 { font-size: 3rem; }
            .proj-grid { grid-template-columns: repeat(3, 1fr); }
            .proj-img { height: 250px; }
        }
    </style>

</Base>
