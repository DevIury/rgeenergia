---
import Base from '../../layouts/Base.astro';
---
<Base title="Serviços RGE Energia | Solar, Eficiência, Projetos" description="Conheça todos os serviços da RGE Energia: energia solar fotovoltaica, eficiência energética, projetos elétricos e subestações em Curvelo/MG.">

    <section class="page-hero">
        <div class="page-hero-bg"><img src="/img/solar-panels.webp" alt="Serviços RGE"><div class="page-hero-overlay"></div></div>
        <div class="container page-hero-content">
            <nav class="breadcrumb"><a href="/">Home</a><span>/</span><span>Serviços</span></nav>
            <h1>Nossos <span>serviços</span></h1>
            <p>Soluções completas em energia para residências, empresas e propriedades rurais</p>
        </div>
    </section>

    <section class="serv-list">
        <div class="container">
            <div class="serv-list-grid">
                <a href="/servicos/energia-solar" class="serv-list-card">
                    <div class="serv-list-img"><img src="/img/solar-panels.webp" alt="Energia Solar"><div class="serv-list-badge">MAIS VENDIDO</div></div>
                    <div class="serv-list-body">
                        <div class="serv-list-icon"><i class="fas fa-solar-panel"></i></div>
                        <h3>Energia Solar Fotovoltaica</h3>
                        <p>Sistema completo para gerar sua própria energia e reduzir a conta de luz em até 95%. Projetos residenciais, comerciais e rurais.</p>
                        <div class="serv-list-features">
                            <span><i class="fas fa-check"></i> Economia de até 95%</span>
                            <span><i class="fas fa-check"></i> Garantia 25 anos</span>
                            <span><i class="fas fa-check"></i> Sem entrada</span>
                        </div>
                        <span class="serv-list-link">Ver detalhes <i class="fas fa-arrow-right"></i></span>
                    </div>
                </a>
                <a href="/servicos/eficiencia-energetica" class="serv-list-card">
                    <div class="serv-list-img"><img src="/img/energy-pylons.webp" alt="Eficiência Energética"></div>
                    <div class="serv-list-body">
                        <div class="serv-list-icon"><i class="fas fa-chart-line"></i></div>
                        <h3>Eficiência Energética</h3>
                        <p>Diagnóstico completo e otimização do consumo. Redução de 20-40% nos custos sem investimento em novos equipamentos.</p>
                        <div class="serv-list-features">
                            <span><i class="fas fa-check"></i> Redução de 20-40%</span>
                            <span><i class="fas fa-check"></i> Diagnóstico completo</span>
                            <span><i class="fas fa-check"></i> Retorno rápido</span>
                        </div>
                        <span class="serv-list-link">Ver detalhes <i class="fas fa-arrow-right"></i></span>
                    </div>
                </a>
                <a href="/servicos/projetos-eletricos" class="serv-list-card">
                    <div class="serv-list-img"><img src="/img/proj-comercial.webp" alt="Projetos Elétricos"></div>
                    <div class="serv-list-body">
                        <div class="serv-list-icon"><i class="fas fa-drafting-compass"></i></div>
                        <h3>Projetos Elétricos</h3>
                        <p>Projetos profissionais com conformidade normativa para residências, comércios e indústrias.</p>
                        <div class="serv-list-features">
                            <span><i class="fas fa-check"></i> Conformidade ABNT</span>
                            <span><i class="fas fa-check"></i> Aprovação garantida</span>
                            <span><i class="fas fa-check"></i> Até 5 anos garantia</span>
                        </div>
                        <span class="serv-list-link">Ver detalhes <i class="fas fa-arrow-right"></i></span>
                    </div>
                </a>
                <a href="/servicos/subestacoes" class="serv-list-card">
                    <div class="serv-list-img"><img src="/img/proj-rural.webp" alt="Subestações"></div>
                    <div class="serv-list-body">
                        <div class="serv-list-icon"><i class="fas fa-network-wired"></i></div>
                        <h3>Subestações</h3>
                        <p>Projeto e instalação de subestações para demanda a partir de 75kVA. Segurança e eficiência.</p>
                        <div class="serv-list-features">
                            <span><i class="fas fa-check"></i> 75kVA a 10.000kVA</span>
                            <span><i class="fas fa-check"></i> Cálculo de demanda</span>
                            <span><i class="fas fa-check"></i> Pós-venda</span>
                        </div>
                        <span class="serv-list-link">Ver detalhes <i class="fas fa-arrow-right"></i></span>
                    </div>
                </a>
                <a href="/servicos/consultoria" class="serv-list-card">
                    <div class="serv-list-img"><img src="/img/energy-pylons.webp" alt="Consultoria"></div>
                    <div class="serv-list-body">
                        <div class="serv-list-icon"><i class="fas fa-lightbulb"></i></div>
                        <h3>Consultoria</h3>
                        <p>Assessoria técnica para empresas e engenheiros. Laudos, pareceres e acompanhamento de obras.</p>
                        <div class="serv-list-features">
                            <span><i class="fas fa-check"></i> Laudos técnicos</span>
                            <span><i class="fas fa-check"></i> Acompanhamento</span>
                            <span><i class="fas fa-check"></i> Assessoria completa</span>
                        </div>
                        <span class="serv-list-link">Ver detalhes <i class="fas fa-arrow-right"></i></span>
                    </div>
                </a>
                <a href="/servicos/geradores" class="serv-list-card">
                    <div class="serv-list-img"><img src="/img/proj-comercial.webp" alt="Grupos Geradores"></div>
                    <div class="serv-list-body">
                        <div class="serv-list-icon"><i class="fas fa-cogs"></i></div>
                        <h3>Grupos Geradores</h3>
                        <p>Dimensionamento e instalação de geradores a diesel e gás para backup e geração de energia.</p>
                        <div class="serv-list-features">
                            <span><i class="fas fa-check"></i> Diesel e gás</span>
                            <span><i class="fas fa-check"></i> Backup confiável</span>
                            <span><i class="fas fa-check"></i> Manutenção</span>
                        </div>
                        <span class="serv-list-link">Ver detalhes <i class="fas fa-arrow-right"></i></span>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container cta-inner">
            <h2>Precisa de um orçamento?</h2>
            <p>Fale com nossa equipe e receba uma proposta personalizada.</p>
            <div class="cta-btns">
                <a href="/contato" class="btn btn-green btn-xl">SOLICITAR ORÇAMENTO <i class="fas fa-arrow-right"></i></a>
                <a href="https://wa.me/5538999901309" class="btn btn-whatsapp btn-xl" target="_blank"><i class="fab fa-whatsapp"></i> WHATSAPP</a>
            </div>
        </div>
    </section>

    <style>
        .page-hero { position: relative; padding: 100px 0 50px; overflow: hidden; }
        .page-hero-bg { position: absolute; inset: 0; }
        .page-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
        .page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,0,0,.9) 0%, rgba(0,0,0,.7) 100%); }
        .page-hero-content { position: relative; z-index: 1; }
        .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: .75rem; color: var(--gray); margin-bottom: 12px; }
        .breadcrumb a { color: var(--green); text-decoration: none; }
        .page-hero h1 { font-family: var(--font-display); font-size: 2rem; color: var(--white); margin-bottom: 8px; }
        .page-hero h1 span { color: var(--green); }
        .page-hero p { color: var(--gray); font-size: .95rem; }

        .serv-list { padding: 60px 0; background: var(--black); }
        .serv-list-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
        .serv-list-card { display: block; background: var(--dark-2); border: 1px solid var(--dark-3); border-radius: var(--radius); overflow: hidden; transition: .3s; }
        .serv-list-card:hover { border-color: var(--green); transform: translateY(-2px); }
        .serv-list-img { position: relative; height: 160px; overflow: hidden; }
        .serv-list-img img { width: 100%; height: 100%; object-fit: cover; }
        .serv-list-badge { position: absolute; top: 10px; right: 10px; padding: 4px 10px; background: var(--green); color: var(--black); font-size: .6rem; font-weight: 700; border-radius: var(--radius-full); }
        .serv-list-body { padding: 20px 16px; }
        .serv-list-icon { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: var(--green); border-radius: 10px; color: var(--black); font-size: 1rem; margin-bottom: 12px; }
        .serv-list-body h3 { color: var(--white); font-size: 1.1rem; margin-bottom: 6px; }
        .serv-list-body p { color: var(--gray); font-size: .85rem; line-height: 1.6; margin-bottom: 12px; }
        .serv-list-features { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
        .serv-list-features span { display: inline-flex; align-items: center; gap: 4px; font-size: .7rem; color: var(--gray-light); background: var(--dark-3); padding: 4px 8px; border-radius: var(--radius-full); }
        .serv-list-features i { color: var(--green); font-size: .6rem; }
        .serv-list-link { display: inline-flex; align-items: center; gap: 4px; color: var(--green); font-weight: 600; font-size: .85rem; }

        .cta-section { padding: 50px 0; background: var(--dark); text-align: center; }
        .cta-inner h2 { font-family: var(--font-display); font-size: 1.5rem; color: var(--white); margin-bottom: 8px; }
        .cta-inner p { color: var(--gray); margin-bottom: 20px; font-size: .9rem; }
        .cta-btns { display: flex; flex-direction: column; gap: 10px; }

        @media(min-width:640px) {
            .page-hero h1 { font-size: 2.5rem; }
            .serv-list-grid { grid-template-columns: repeat(2, 1fr); }
            .cta-btns { flex-direction: row; justify-content: center; }
        }
        @media(min-width:1024px) {
            .page-hero { padding: 140px 0 60px; }
            .page-hero h1 { font-size: 3rem; }
            .serv-list-grid { grid-template-columns: repeat(3, 1fr); }
        }
    </style>

</Base>
