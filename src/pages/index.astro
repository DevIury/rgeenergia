    <script>
        const nums = document.querySelectorAll('.num-val');
        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    const el = e.target as HTMLElement;
                    const target = parseInt(el.dataset.target || '0');
                    let cur = 0; const step = target / 60;
                    const timer = setInterval(() => {
                        cur += step;
                        if (cur >= target) { el.textContent = target >= 1000000 ? (target/1000000).toFixed(1)+'M' : target.toLocaleString('pt-BR'); clearInterval(timer); }
                        else { el.textContent = Math.floor(cur).toLocaleString('pt-BR'); }
                    }, 25);
                    obs.unobserve(el);
                }
            });
        }, { threshold: .5 });
        nums.forEach(n => obs.observe(n));

        const revealObs = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: .1 });
        document.querySelectorAll('.serv-card, .proj-card, .depo-card, .passo, .num-card, .blog-card').forEach(el => { el.classList.add('reveal'); revealObs.observe(el); });
        const st = document.createElement('style');
        st.textContent = '.reveal{opacity:0;transform:translateY(20px);transition:opacity .5s,transform .5s}.reveal.visible{opacity:1;transform:none}';
        document.head.appendChild(st);
    </script>

    <style>
        /* HERO */
        .hero { position: relative; min-height: 100svh; display: flex; align-items: center; overflow: hidden; }
        .hero-bg { position: absolute; inset: 0; }
        .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
        .hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,0,0,.9) 0%, rgba(0,0,0,.7) 100%); }
        .hero-content { position: relative; z-index: 1; padding: 100px 0 60px; width: 100%; }
        .hero-badge { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; background: rgba(34,197,94,.15); border: 1px solid rgba(34,197,94,.3); border-radius: var(--radius-full); color: var(--green); font-size: .7rem; font-weight: 600; margin-bottom: 20px; }
        .hero h1 { font-family: var(--font-display); font-size: clamp(1.6rem, 8vw, 3.5rem); color: var(--white); line-height: 1.1; margin-bottom: 16px; }
        .hero h1 span { color: var(--green); }
        .hero p { font-size: .9rem; color: var(--gray); line-height: 1.6; margin-bottom: 24px; max-width: 450px; }
        .hero p strong { color: var(--green); }
        .hero-btns { display: flex; flex-direction: column; gap: 10px; margin-bottom: 32px; }
        .hero-trust { display: flex; flex-wrap: wrap; gap: 16px; }
        .trust { display: flex; align-items: center; gap: 6px; font-size: .75rem; color: var(--gray); }
        .trust i { color: var(--green); }

        /* URGÊNCIA */
        .urgencia {
            padding: 20px 0;
            background: var(--black);
        }
        .urgencia-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 14px;
            text-align: center;
            padding: 28px 24px;
            background: linear-gradient(135deg, rgba(34,197,94,.1), rgba(34,197,94,.03));
            border: 1px solid rgba(34,197,94,.2);
            border-radius: 16px;
        }
        .urg-icon-wrap {
            position: relative;
            width: 48px; height: 48px;
            display: flex; align-items: center; justify-content: center;
        }
        .urg-icon-wrap i {
            font-size: 1.15rem; color: var(--green);
            position: relative; z-index: 1;
            filter: drop-shadow(0 0 8px rgba(34,197,94,.5));
        }
        .urg-icon-ring {
            position: absolute; inset: 0;
            border-radius: 50%;
            border: 1.5px solid rgba(34,197,94,.3);
            animation: urg-ring 2.5s ease-out infinite;
        }
        .urg-icon-ring-2 { animation-delay: .8s; }
        @keyframes urg-ring {
            0% { transform: scale(.8); opacity: 1; }
            100% { transform: scale(1.8); opacity: 0; }
        }
        .urg-title {
            background: linear-gradient(135deg, var(--green), #4ade80);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: .9rem;
            font-weight: 700;
            letter-spacing: .08em;
        }
        .urg-desc {
            color: rgba(255,255,255,.5);
            font-size: .82rem;
        }
        .urg-btn {
            display: inline-flex; align-items: center; gap: 10px;
            padding: 12px 28px;
            background: var(--green);
            color: var(--black);
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .06em;
            border-radius: 50px;
            transition: all .3s;
            box-shadow: 0 4px 20px rgba(34,197,94,.3);
        }
        .urg-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(34,197,94,.5);
        }
        .urg-btn i { font-size: .65rem; transition: transform .3s; }
        .urg-btn:hover i { transform: translateX(3px); }

        /* SOBRE */
        .sobre { padding: 60px 0; background: var(--dark); }
        .sobre-grid { display: grid; grid-template-columns: 1fr; gap: 32px; }
        .sobre-visual { position: relative; }
        .sobre-img-main { width: 100%; height: 250px; object-fit: cover; border-radius: var(--radius); }
        .sobre-badge { position: absolute; bottom: 12px; right: 12px; background: var(--green); color: var(--black); padding: 12px 16px; border-radius: var(--radius-sm); text-align: center; }
        .sobre-badge strong { display: block; font-family: var(--font-display); font-size: 1.5rem; }
        .sobre-badge span { font-size: .7rem; font-weight: 600; }
        .sobre-text h2 { font-family: var(--font-display); font-size: 1.6rem; color: var(--white); margin-bottom: 12px; }
        .sobre-text h2 span { color: var(--green); }
        .sobre-text > p { color: var(--gray); line-height: 1.6; margin-bottom: 16px; font-size: .95rem; }
        .sobre-text > p strong { color: var(--white); }
        .sobre-feats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
        .feat { display: flex; align-items: center; gap: 6px; font-size: .85rem; color: var(--gray-light); }
        .feat i { color: var(--green); }

        /* SERVIÇOS */
        .servicos {
            padding: 100px 0 80px;
            background: var(--black);
            position: relative; overflow: hidden;
        }
        .serv-bg-dots {
            position: absolute; inset: 0;
            background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
            background-size: 24px 24px;
            pointer-events: none;
        }
        .serv-glow {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            filter: blur(120px);
        }
        .serv-glow-1 { top: -150px; right: -100px; width: 500px; height: 500px; background: rgba(34,197,94,.07); }
        .serv-glow-2 { bottom: -200px; left: -150px; width: 400px; height: 400px; background: rgba(34,197,94,.04); }

        .serv-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .serv-card {
            display: flex; flex-direction: column;
            background: linear-gradient(160deg, rgba(255,255,255,.04) 0%, rgba(255,255,255,.01) 100%);
